{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@screens/*": [
                "src/screens/*"
            ],
            "@components/*": [
                "src/components/*"
            ],
            "@hooks/*": [
                "src/hooks/*"
            ],
            "@services/*": [
                "src/services/*"
            ],
            "@utils/*": [
                "src/utils/*"
            ],
            "@context/*": [
                "src/context/*"
            ],
            "@navigation/*": [
                "src/navigation/*"
            ],
            "@constants/*": [
                "src/constants/*"
            ],
            "@app-types/*": [
                "src/types/*"
            ],
            "@assets/*": [
                "src/assets/*"
            ]
        }
    },
    "include": [
        "src/**/*",
        "App.tsx",
        "index.ts"
    ]
}